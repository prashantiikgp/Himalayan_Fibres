# Vite env vars consumed at build time. Copy to .env.local for local dev.
# All vars MUST start with VITE_ to be exposed to the client bundle.

# Sentry — error tracking (per STANDARDS §3)
# Get from sentry.io project settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# PostHog — analytics (per STANDARDS §3)
# Get from app.posthog.com → Project settings → Project API Key
VITE_POSTHOG_KEY=

# Backend API base URL. Leave blank to use the same origin (production: /api/v2).
# In dev, vite.config.ts proxies /api/v2 → http://localhost:7860 so this can stay blank.
VITE_API_BASE=

# Build-time toggles
VITE_APP_ENV=development
