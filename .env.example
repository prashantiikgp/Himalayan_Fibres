# ===========================================
# RATE LIMITS
# ===========================================
# Gmail limits: 500/day (free) or 2000/day (Workspace)
EMAIL_DAILY_LIMIT=500
EMAIL_RATE_LIMIT_PER_MINUTE=20
CAMPAIGN_BATCH_SIZE=50
CAMPAIGN_BATCH_DELAY_SECONDS=60

# ===========================================
# CART ABANDONMENT SETTINGS
# ===========================================
CART_ABANDONED_DELAY_1H=3600      # 1 hour in seconds
CART_ABANDONED_DELAY_24H=86400   # 24 hours in seconds
CART_ABANDONED_DELAY_72H=259200  # 72 hours in seconds

# ===========================================
# WEBHOOK TUNNEL (for local development)
# ===========================================
# If using ngrok, set your tunnel URL here
# WEBHOOK_BASE_URL=https://your-tunnel.ngrok.io
WEBHOOK_BASE_URL=http://localhost:8000
