      "locked": false,
      "type": "text",
      "text": "  \u2022 Local file = git-versioned. New image = git add + commit + deploy",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
