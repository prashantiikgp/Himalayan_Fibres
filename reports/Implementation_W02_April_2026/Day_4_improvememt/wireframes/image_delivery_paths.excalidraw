      "isDeleted": false,
      "boundElements": null,
      "updated": 1778054213733,
      "link": null,
      "locked": false,
      "type": "text",
      "text": "  \u2022 Meta has the image at delivery time \u2014 no external fetch, no fetcher failures",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "  \u2022 Meta has the image at delivery time \u2014 no external fetch, no fetcher failures",
      "lineHeight": 1.25
    },
    {
      "id": "el0064",
      "x": 80,
      "y": 778,
      "width": 1100,
      "height": 14,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1810145000,
      "version": 1,
      "versionNonce": 203588199,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1778054213733,
      "link": null,
      "locked": false,
      "type": "text",
      "text": "  \u2022 The image never needs to be public \u2014 bypasses URL exposure / CDN expiry",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 10,
      "containerId": null,
      "originalText": "  \u2022 The image never needs to be public \u2014 bypasses URL exposure / CDN expiry",
      "lineHeight": 1.25
    },
